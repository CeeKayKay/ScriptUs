# ============================================
# SCRIPTUS — Environment Configuration
# ============================================
# Copy this file to .env.local and fill in values

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://user:password@localhost:5432/scriptus?schema=public"

# ---- NextAuth ----
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here-use-openssl-rand-base64-32"

# ---- OAuth Providers (enable one or more) ----
# Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub (good for dev teams)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ---- WebSocket Server ----
WS_PORT=1234
NEXT_PUBLIC_WS_URL="ws://localhost:1234"

# ---- Optional ----
# Set to "true" to enable demo mode with seed data
DEMO_MODE="false"
